# ===============================
# Maantra Environment Configuration
# ===============================
# Copy this file to `.env` and fill in your own API keys.
#
# Example:
# cp .env.example .env
#
# The system will automatically load these variables when running the project.
# You can change providers, models, and integrations according to your needs.

# -------------------------------------------------
# Slack Configuration
# -------------------------------------------------
# Create a Slack App and obtain these credentials
# from https://api.slack.com/apps

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_USER_TOKEN=

# -------------------------------------------------
# LLM Provider API Keys
# -------------------------------------------------
# Provide the key for the model provider you want to use.
# You can switch providers without changing the code.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
COHERE_API_KEY=

# -------------------------------------------------
# Memory System
# -------------------------------------------------
# API key for mem0 (long-term AI memory service)

MEM0_API_KEY=

# -------------------------------------------------
# MCP Integrations
# -------------------------------------------------
# Tokens used for external integrations via MCP servers.

GITHUB_PERSONAL_ACCESS_TOKEN=
NOTION_API_TOKEN=

# -------------------------------------------------
# Model Configuration
# -------------------------------------------------
# Set the default model used by the agent.
# You can change this to any supported model.

DEFAULT_MODEL=claude-sonnet-4-20250514

# Examples:
# DEFAULT_MODEL=gpt-4o
# DEFAULT_MODEL=gemini-1.5-pro

# -------------------------------------------------
# Logging
# -------------------------------------------------

LOG_LEVEL=info

# Options:
# debug
# info
# warning
# error

# -------------------------------------------------
# Local Database
# -------------------------------------------------
# Path to the SQLite database used for session memory.

DATABASE_PATH=./data/assistant.db

# -------------------------------------------------
# Telegram Configuration
# -------------------------------------------------
# Create bot via @BotFather and paste token here

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# -------------------------------------------------
# WhatsApp Configuration (Twilio)
# -------------------------------------------------
# Create Twilio account and WhatsApp sender

WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
